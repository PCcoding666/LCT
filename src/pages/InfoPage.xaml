<Page
    x:Class="LiveCaptionsTranslator.InfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiveCaptionsTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="InfoPage"
    mc:Ignorable="d">

    <ScrollViewer>
        <ui:Card Margin="20" Padding="25">
            <StackPanel>
                <!-- 应用标题 -->
                <TextBlock 
                    Text="Dell LiveCaptions Translator (Local Edition)" 
                    FontSize="20" 
                    FontWeight="Bold" 
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"/>
                
                <!-- 版本信息 -->
                <ui:Card Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Version Information" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Version: 1.0.0 Dell Edition" Margin="0,0,0,5"/>
                        <TextBlock Text="Build Date: 2024-01-01" Margin="0,0,0,5"/>
                        <TextBlock Text="Translation Engine: Ollama" Margin="0,0,0,5"/>
                    </StackPanel>
                </ui:Card>
                
                <!-- 功能特性 -->
                <ui:Card Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Features" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="• Real-time translation using Ollama local AI" Margin="0,0,0,5"/>
                        <TextBlock Text="• Integration with Windows Live Captions" Margin="0,0,0,5"/>
                        <TextBlock Text="• Context-aware translation" Margin="0,0,0,5"/>
                        <TextBlock Text="• Customizable overlay window" Margin="0,0,0,5"/>
                        <TextBlock Text="• Translation history management" Margin="0,0,0,5"/>
                    </StackPanel>
                </ui:Card>
                
                <!-- 技术支持 -->
                <ui:Card Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Technical Support" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="For technical support and documentation, please contact:" Margin="0,0,0,5"/>
                        <TextBlock Text="e1143754@u.nus.edu" Margin="0,0,0,5"/>
                    </StackPanel>
                </ui:Card>
                
                <!-- 关于 -->
                <ui:Card Padding="15">
                    <StackPanel>
                        <TextBlock Text="About" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="This Dell customized edition provides local AI-powered translation" Margin="0,0,0,5"/>
                        <TextBlock Text="capabilities using Ollama, ensuring privacy and performance." Margin="0,0,0,5"/>
                        <TextBlock Text="© 2024 Dell Technologies. All rights reserved." Margin="0,10,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ui:Card>
    </ScrollViewer>
</Page>