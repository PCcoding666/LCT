<UserControl x:Class="LiveCaptionsTranslator.Controls.VersionSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        
        <Style x:Key="SettingGroupStyle" TargetType="ui:Card">
            <Setter Property="Margin" Value="0,0,0,15" />
            <Setter Property="Padding" Value="20" />
        </Style>
        
        <Style x:Key="SettingTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        
        <Style x:Key="SettingDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
        
        <Style x:Key="InfoTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10">
            
            <!-- Version Information -->
            <ui:Card Style="{StaticResource SettingGroupStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Version Information" Style="{StaticResource SettingTitleStyle}" />
                            <TextBlock Text="{Binding CurrentVersion}" Style="{StaticResource InfoTextStyle}" FontWeight="Medium" />
                            <TextBlock Text="Last update check:" Style="{StaticResource InfoTextStyle}" />
                            <TextBlock Text="{Binding LastCheckTime}" Style="{StaticResource InfoTextStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <ui:Button Content="View Details" 
                                      Click="OnViewVersionInfoClick" 
                                      Appearance="Secondary" 
                                      Margin="5,0" />
                            <ui:Button Content="Check for Updates" 
                                      Click="OnCheckForUpdatesClick" 
                                      Appearance="Primary" 
                                      IsEnabled="{Binding CanCheckForUpdates}" 
                                      Margin="5,0" />
                        </StackPanel>
                    </Grid>
                    
                    <!-- Update Progress -->
                    <StackPanel Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BoolToVisConverter}}" 
                               Margin="0,15,0,0">
                        <TextBlock Text="Checking for updates..." Style="{StaticResource InfoTextStyle}" />
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,5,0,0" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
            
            <!-- Automatic Updates -->
            <ui:Card Style="{StaticResource SettingGroupStyle}">
                <StackPanel>
                    <TextBlock Text="Automatic Updates" Style="{StaticResource SettingTitleStyle}" />
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <ui:ToggleSwitch IsChecked="{Binding AutoUpdateEnabled}" 
                                        Margin="0,0,15,0" />
                        <StackPanel>
                            <TextBlock Text="Enable automatic updates" FontSize="14" FontWeight="Medium" />
                            <TextBlock Text="Automatically check for and download updates in the background" 
                                      Style="{StaticResource SettingDescriptionStyle}" />
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Update Frequency -->
                    <Grid IsEnabled="{Binding AutoUpdateEnabled}" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="Check frequency:" 
                                  Grid.Column="0" 
                                  VerticalAlignment="Center" 
                                  Margin="0,0,10,0" 
                                  FontSize="14" />
                        
                        <ComboBox Grid.Column="1" 
                                 SelectedValue="{Binding UpdateInterval}" 
                                 SelectedValuePath="Tag" 
                                 MinWidth="120" 
                                 VerticalAlignment="Center">
                            <ComboBoxItem Content="Every hour" Tag="1" />
                            <ComboBoxItem Content="Every 6 hours" Tag="6" />
                            <ComboBoxItem Content="Every 12 hours" Tag="12" />
                            <ComboBoxItem Content="Daily" Tag="24" />
                            <ComboBoxItem Content="Every 3 days" Tag="72" />
                            <ComboBoxItem Content="Weekly" Tag="168" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ui:Card>
            
            <!-- Advanced Options -->
            <ui:Card Style="{StaticResource SettingGroupStyle}">
                <StackPanel>
                    <TextBlock Text="Advanced Options" Style="{StaticResource SettingTitleStyle}" />
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <ui:ToggleSwitch IsChecked="{Binding AllowPreRelease}" 
                                        Margin="0,0,15,0" />
                        <StackPanel>
                            <TextBlock Text="Include pre-release versions" FontSize="14" FontWeight="Medium" />
                            <TextBlock Text="Receive beta and release candidate versions for early testing" 
                                      Style="{StaticResource SettingDescriptionStyle}" />
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Additional Actions -->
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <ui:Button Content="Open Update Folder" 
                                  Click="OnOpenUpdateFolderClick" 
                                  Appearance="Secondary" 
                                  Margin="0,0,10,0" />
                        
                        <!-- Future: Reset Update Settings -->
                        <!--
                        <ui:Button Content="Reset Settings" 
                                  Appearance="Secondary" 
                                  Margin="0,0,10,0" />
                        -->
                    </StackPanel>
                </StackPanel>
            </ui:Card>
            
            <!-- Update Information -->
            <ui:InfoBar Title="About Automatic Updates" 
                       Severity="Informational" 
                       IsOpen="True" 
                       IsClosable="False">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" 
                              Text="• Updates are downloaded in the background and installed when you restart the application" />
                    <TextBlock TextWrapping="Wrap" 
                              Text="• Critical security updates may be installed automatically" />
                    <TextBlock TextWrapping="Wrap" 
                              Text="• You can always check for updates manually or disable automatic updates" />
                    <TextBlock TextWrapping="Wrap" 
                              Text="• All downloaded updates are verified for integrity before installation" />
                </StackPanel>
            </ui:InfoBar>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>