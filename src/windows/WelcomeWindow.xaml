<ui:FluentWindow
    x:Class="LiveCaptionsTranslator.WelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiveCaptionsTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Getting Started"
    Width="750"
    Height="580"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    Icon="/images/LCT_logo.ico"
    ResizeMode="NoResize"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Height="27"
            ShowMaximize="False"
            ShowMinimize="False">
            <ui:TitleBar.Header>
                <ui:TextBlock Padding="15,0,0,0" VerticalAlignment="Center">
                    Getting Started
                </ui:TextBlock>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Background="{ui:ThemeResource SystemFillColorNeutralBackgroundBrush}">
            <Image Source="/images/LCT_logo.png" Width="100" Height="100" Margin="20,10,20,0" HorizontalAlignment="Center" />
            <TextBlock
                Margin="20"
                HorizontalAlignment="Left"
                FontSize="24"
                FontWeight="Bold"
                Text="Welcome to LCT (LiveCaptions Translator)!"
                TextAlignment="Left" />
            <ui:TextBlock
                Margin="20,10,20,10"
                TextAlignment="Left"
                TextWrapping="Wrap">
                <Run Text="LCT (LiveCaptions Translator) combines Windows Live Captions with local AI translation." />
                <Run FontWeight="Bold" Text="&#x0A;&#x0A;⚠️ Important: Complete the following configuration before first use:" />
                
                <Run Text="&#x0A;&#x0A;" />
                <Run FontWeight="Bold" Text="Step 1: Configure Windows Live Captions" />
                <Run Text="&#x0A;When you first launch Windows Live Captions, it will:" />
                <Run Text="&#x0A;• Request permission to process speech data on your device" />
                <Run Text="&#x0A;• Prompt you to download language files for speech recognition" />
                
                <Run Text="&#x0A;&#x0A;After initial setup, configure the following settings:" />
                <Run Text="&#x0A;1. Click the " />
                <Run FontWeight="Bold" Text="⚙️ gear icon" />
                <Run Text=" in Live Captions" />
                <Run Text="&#x0A;2. In " />
                <Run FontWeight="Bold" Text="'Change language'" />
                <Run Text=", select your " />
                <Run FontWeight="Bold" Text="source language" />
                <Run Text=" (the language to be recognized)" />
                <Run Text="&#x0A;3. Under " />
                <Run FontWeight="Bold" Text="Position" />
                <Run Text=", select " />
                <Run FontWeight="Bold" Text="'Overlaid on screen'" />
                <Run Text="&#x0A;4. Click the " />
                <Run FontWeight="Bold" Text="'Hide'" />
                <Run Text=" button in LCT's settings page to hide Live Captions" />
                
                <Run Text="&#x0A;&#x0A;" />
                <Run FontWeight="Bold" Text="Step 2: Enable Microphone Audio (Optional)" />
                <Run Text="&#x0A;To translate your own speech through the microphone:" />
                <Run Text="&#x0A;1. In Live Captions, click the " />
                <Run FontWeight="Bold" Text="⚙️ gear icon" />
                <Run Text="&#x0A;2. Go to " />
                <Run FontWeight="Bold" Text="Preferences" />
                <Run Text="&#x0A;3. Check " />
                <Run FontWeight="Bold" Text="'Include microphone audio'" />
                
                <Run Text="&#x0A;&#x0A;🎉 " />
                <Run FontWeight="Bold" Text="Ready to Start!" />
                <Run Text=" The program has automatically opened Windows Live Captions and navigated to the settings page. After configuration, return to the main page to enjoy real-time translation!" />
                
                <Run Text="&#x0A;&#x0A;" />
                <Run Text="Official website: " />
                <Hyperlink NavigateUri="https://aiallyouneed.dev" RequestNavigate="Hyperlink_RequestNavigate">
                    https://aiallyouneed.dev
                </Hyperlink>
            </ui:TextBlock>

            <ui:Button
                Margin="0,10,0,0"
                Padding="30,10,30,10"
                HorizontalAlignment="Center"
                Click="CloseButton_Click"
                Content="I have fully understood and configured." />
        </StackPanel>
    </Grid>
</ui:FluentWindow>