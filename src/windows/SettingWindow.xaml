<ui:FluentWindow
    x:Class="LiveCaptionsTranslator.SettingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiveCaptionsTranslator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Ollama Configuration"
    Width="500"
    Height="420"
    d:DesignHeight="420"
    d:DesignWidth="500"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Ollama Configuration" ShowMaximize="False" />

        <!-- 主要内容区域 -->
        <Grid Grid.Row="1" Margin="20">
            <!-- 深色圆角容器 -->
            <ui:Card Padding="20" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel>
                    <!-- 标题区 -->
                    <TextBlock Text="Ollama" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    
                    <!-- 配置档案管理区 -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- 左侧 - 配置切换器 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Current Config:" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:Button x:Name="PrevConfigButton" Content="&lt;" Width="30" Height="30" Padding="0" Margin="0,0,5,0" Appearance="Secondary" Click="PrevConfigButton_Click"/>
                            <TextBlock x:Name="ConfigIndicator" Text="1/1" VerticalAlignment="Center" Margin="5,0,5,0" MinWidth="30" TextAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:Button x:Name="NextConfigButton" Content="&gt;" Width="30" Height="30" Padding="0" Margin="5,0,0,0" Appearance="Secondary" Click="NextConfigButton_Click"/>
                        </StackPanel>
                        
                        <!-- 右侧 - 操作按钮 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button x:Name="NewConfigButton" Content="New" Margin="0,0,10,0" Appearance="Secondary" Click="NewConfigButton_Click"/>
                            <ui:Button x:Name="DeleteConfigButton" Content="Delete" Appearance="Secondary" Click="DeleteConfigButton_Click"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- 分割线 -->
                    <Separator Margin="0,0,0,20" Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                    
                    <!-- 配置详情区 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 模型名称 -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                            <TextBlock Text="Model Name" Margin="0,0,0,5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ComboBox x:Name="ModelNameComboBox" 
                                     Text="{Binding OllamaConfig.ModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValue="{Binding OllamaConfig.ModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="Key"
                                     DisplayMemberPath="Value"
                                     IsEditable="True"/>
                        </StackPanel>
                        
                        <!-- 端口 -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,15">
                            <TextBlock Text="Port" Margin="0,0,0,5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox Text="{Binding OllamaConfig.Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        
                        <!-- 主机地址 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                            <TextBlock Text="Host Address" Margin="0,0,0,5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox Text="{Binding OllamaConfig.Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        
                        <!-- Temperature -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,15">
                            <TextBlock Text="Temperature" Margin="0,0,0,5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:NumberBox x:Name="TemperatureNumberBox" 
                                         Value="{Binding OllamaConfig.Temperature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         Minimum="0" Maximum="2" 
                                         SmallChange="0.1" LargeChange="0.5" 
                                         SpinButtonPlacementMode="Inline" />
                        </StackPanel>
                        
                        <!-- 超时设置 -->
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,15">
                            <TextBlock Text="Timeout (seconds)" Margin="0,0,0,5" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:NumberBox x:Name="TimeoutNumberBox" 
                                         Value="{Binding OllamaConfig.TimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         Minimum="10" Maximum="300" 
                                         SmallChange="10" LargeChange="30" 
                                         SpinButtonPlacementMode="Inline" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </Grid>

        <!-- 底部按钮区域 -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,15">
                <ui:Button
                    x:Name="SaveButton"
                    Content="Save Settings"
                    Appearance="Primary"
                    Click="SaveButton_Click"
                    Margin="0,0,10,0">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Save24" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button
                    x:Name="CloseButton"
                    Content="Close"
                    Click="CloseButton_Click">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Dismiss24" />
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>