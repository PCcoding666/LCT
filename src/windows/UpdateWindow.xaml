<ui:FluentWindow x:Class="LiveCaptionsTranslator.Windows.UpdateWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                Title="Software Update"
                Width="600"
                Height="500"
                WindowStartupLocation="CenterOwner"
                ResizeMode="NoResize"
                ShowInTaskbar="False"
                Icon="/images/AppIcon.ico">
    
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        
        <Style x:Key="InfoTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        
        <Style x:Key="ActionButtonStyle" TargetType="ui:Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinWidth" Value="120" />
        </Style>
    </ui:FluentWindow.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <ui:SymbolIcon Symbol="ArrowDownload24" 
                          FontSize="48" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,15"
                          Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
            
            <TextBlock Text="{Binding UpdateTitle}" 
                      FontSize="20" 
                      FontWeight="SemiBold" 
                      HorizontalAlignment="Center" 
                      Margin="0,0,0,10" />
            
            <TextBlock Text="{Binding UpdateSize}" 
                      Style="{StaticResource InfoTextStyle}" 
                      HorizontalAlignment="Center" 
                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>
        
        <!-- Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,20">
            
            <StackPanel>
                <!-- Update Information -->
                <ui:CardExpander Header="What's New in This Version" 
                                IsExpanded="True" 
                                Margin="0,0,0,15">
                    <ui:CardExpander.Icon>
                        <ui:SymbolIcon Symbol="Info24" />
                    </ui:CardExpander.Icon>
                    
                    <StackPanel Margin="15">
                        <TextBlock Text="{Binding UpdateDescription}" 
                                  Style="{StaticResource InfoTextStyle}" />
                        
                        <ui:Button Content="View Full Changelog" 
                                  Click="OnViewChangelogClick" 
                                  Appearance="Secondary" 
                                  Margin="0,10,0,0" 
                                  HorizontalAlignment="Left"
                                  Visibility="{Binding UpdateInfo.ChangelogUrl, Converter={StaticResource BoolToVisConverter}}" />
                    </StackPanel>
                </ui:CardExpander>
                
                <!-- Download Progress -->
                <ui:Card Margin="0,0,0,15" 
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel Margin="15">
                        <TextBlock Text="Download Progress" 
                                  FontWeight="SemiBold" 
                                  Margin="0,0,0,10" />
                        
                        <ProgressBar Value="{Binding DownloadProgress}" 
                                    Height="8" 
                                    Margin="0,0,0,10" />
                        
                        <TextBlock Text="{Binding DownloadStatus}" 
                                  Style="{StaticResource InfoTextStyle}" 
                                  HorizontalAlignment="Center" />
                    </StackPanel>
                </ui:Card>
                
                <!-- Success Message -->
                <ui:InfoBar Title="Download Complete" 
                           Message="The update has been downloaded and is ready to install. Click 'Install Now' to proceed." 
                           Severity="Success" 
                           IsOpen="{Binding CanInstall}" 
                           Margin="0,0,0,15" />
                
                <!-- System Requirements -->
                <ui:CardExpander Header="System Requirements" 
                                IsExpanded="False">
                    <ui:CardExpander.Icon>
                        <ui:SymbolIcon Symbol="Desktop24" />
                    </ui:CardExpander.Icon>
                    
                    <StackPanel Margin="15">
                        <TextBlock Text="• Windows 10 version 1903 or later" Style="{StaticResource InfoTextStyle}" />
                        <TextBlock Text="• .NET 8.0 Runtime (included in installer)" Style="{StaticResource InfoTextStyle}" />
                        <TextBlock Text="• Visual C++ 2015-2022 Redistributable (included)" Style="{StaticResource InfoTextStyle}" />
                        <TextBlock Text="• At least 100MB free disk space" Style="{StaticResource InfoTextStyle}" />
                        <TextBlock Text="• Administrator privileges for installation" Style="{StaticResource InfoTextStyle}" />
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Warning for Critical Updates -->
        <ui:InfoBar Grid.Row="2" 
                   Title="Critical Update" 
                   Message="This is a critical security update. We strongly recommend installing it immediately." 
                   Severity="Warning" 
                   IsOpen="{Binding UpdateInfo.Critical}" 
                   Margin="0,0,0,15" />
        
        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right">
            
            <!-- Download Button -->
            <ui:Button Content="Download Update" 
                      Click="OnDownloadClick" 
                      Appearance="Primary" 
                      Style="{StaticResource ActionButtonStyle}"
                      IsEnabled="{Binding CanDownload}" 
                      Visibility="{Binding CanDownload, Converter={StaticResource BoolToVisConverter}}" />
            
            <!-- Install Button -->
            <ui:Button Content="Install Now" 
                      Click="OnInstallClick" 
                      Appearance="Primary" 
                      Style="{StaticResource ActionButtonStyle}"
                      IsEnabled="{Binding CanInstall}" 
                      Visibility="{Binding CanInstall, Converter={StaticResource BoolToVisConverter}}" />
            
            <!-- Cancel/Stop Button -->
            <ui:Button Content="{Binding IsDownloading, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Stop Download|Cancel'}" 
                      Click="OnCancelClick" 
                      Appearance="Secondary" 
                      Style="{StaticResource ActionButtonStyle}" />
            
            <!-- Skip Version Button -->
            <ui:Button Content="Skip This Version" 
                      Click="OnSkipVersionClick" 
                      Appearance="Secondary" 
                      Style="{StaticResource ActionButtonStyle}"
                      Visibility="{Binding CanDownload, Converter={StaticResource BoolToVisConverter}}" />
            
            <!-- Remind Later Button -->
            <ui:Button Content="Remind Me Later" 
                      Click="OnRemindLaterClick" 
                      Appearance="Secondary" 
                      Style="{StaticResource ActionButtonStyle}"
                      Visibility="{Binding CanDownload, Converter={StaticResource BoolToVisConverter}}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>