<Window x:Class="LiveCaptionsTranslator.windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dell LiveCaptions Translator" 
        Height="300" 
        Width="500"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1e1e1e">
    
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="20">
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="/src/resources/dell_logo.png" Width="50" Height="50" Margin="0,0,15,0"/>
                <TextBlock Grid.Column="1" 
                           Text="Dell LiveCaptions Translator"
                           Foreground="White"
                           FontSize="24"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
            </Grid>
            
            <TextBlock x:Name="StatusText"
                       Foreground="White"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Left"
                       Text="Initializing..."/>
            
            <ProgressBar x:Name="ProgressBar"
                        Height="5"
                        Margin="0,15,0,5"
                        Value="0"
                        Maximum="100"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StepText"
                           Foreground="#a0a0a0"
                           TextWrapping="Wrap"
                           FontSize="11"
                           HorizontalAlignment="Left"
                           Text="Preparing environment..."/>
                <TextBlock x:Name="ProgressText" 
                           Grid.Column="1"
                           Foreground="#a0a0a0"
                           FontSize="11"
                           HorizontalAlignment="Right"
                           Text="0%"/>
            </Grid>
            
            <ItemsControl x:Name="StepsItemsControl" Margin="0,15,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="StatusIcon" Grid.Column="0" Text="☐" Foreground="#a0a0a0" Margin="0,0,5,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="#a0a0a0"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                <Setter TargetName="StatusIcon" Property="Text" Value="⟳"/>
                                <Setter TargetName="StatusIcon" Property="Foreground" Value="Yellow"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                <Setter TargetName="StatusIcon" Property="Text" Value="✓"/>
                                <Setter TargetName="StatusIcon" Property="Foreground" Value="LightGreen"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                <Setter TargetName="StatusIcon" Property="Text" Value="✕"/>
                                <Setter TargetName="StatusIcon" Property="Foreground" Value="Red"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border BorderBrush="#404040" BorderThickness="1" Margin="0,15,0,0" CornerRadius="3">
                <ScrollViewer x:Name="LogScrollViewer" Height="80" 
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Auto"
                              CanContentScroll="True"
                              ScrollChanged="LogScrollViewer_ScrollChanged">
                    <TextBox x:Name="LogTextBox" 
                             IsReadOnly="True" 
                             Background="Transparent" 
                             Foreground="#a0a0a0" 
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="10"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Hidden"
                             HorizontalScrollBarVisibility="Hidden"/>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</Window> 