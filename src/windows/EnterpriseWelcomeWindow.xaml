<ui:FluentWindow
    x:Class="LiveCaptionsTranslator.windows.EnterpriseWelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LiveCaptionsTranslator.windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Dell Enterprise Setup"
    Width="700"
    Height="520"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Height="27"
            ShowMaximize="False"
            ShowMinimize="False">
            <ui:TitleBar.Header>
                <ui:TextBlock Padding="15,0,0,0" VerticalAlignment="Center">
                    Dell Enterprise Setup
                </ui:TextBlock>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Background="{ui:ThemeResource SystemFillColorNeutralBackgroundBrush}">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="/src/resources/dell_logo.png" Width="60" Height="60" Margin="0,0,15,0"/>
                <TextBlock Grid.Column="1"
                    HorizontalAlignment="Left"
                    FontSize="24"
                    FontWeight="Bold"
                    Text="Welcome to Dell LiveCaptions Translator"
                    TextAlignment="Left" 
                    VerticalAlignment="Center"/>
            </Grid>
            
            <ui:TextBlock
                Margin="20,5,20,10"
                TextAlignment="Left"
                TextWrapping="Wrap">
                <Run Text="This enterprise deployment provides seamless real-time translation powered by local AI." />
                <Run Text="The system has been pre-configured for your environment with the following features:" />
            </ui:TextBlock>
            
            <ui:Card Margin="20,5">
                <ui:CardControl Icon="✓" Header="Local AI Processing">
                    All translation happens on your device using Ollama and optimized models
                </ui:CardControl>
            </ui:Card>
            
            <ui:Card Margin="20,5">
                <ui:CardControl Icon="✓" Header="Automatic Configuration">
                    Windows LiveCaptions integration has been pre-configured
                </ui:CardControl>
            </ui:Card>
            
            <ui:Card Margin="20,5">
                <ui:CardControl Icon="✓" Header="Enterprise-Ready">
                    No data leaves your device, ensuring compliance with privacy requirements
                </ui:CardControl>
            </ui:Card>

            <StackPanel Margin="20,15,20,0">
                <ui:ToggleSwitch x:Name="AutoStartToggle" Content="Automatically start on Windows login" IsChecked="True" />
                <ui:ToggleSwitch x:Name="AnonymousStatsToggle" Content="Send anonymous usage statistics" IsChecked="False" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <ui:Button
                    Margin="0,10,10,0"
                    Padding="30,10,30,10"
                    Appearance="Secondary"
                    HorizontalAlignment="Center"
                    Click="AdvancedButton_Click"
                    Content="Advanced Settings" />
                    
                <ui:Button
                    Margin="10,10,0,0"
                    Padding="30,10,30,10"
                    Appearance="Primary"
                    HorizontalAlignment="Center"
                    Click="ContinueButton_Click"
                    Content="Continue" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow> 